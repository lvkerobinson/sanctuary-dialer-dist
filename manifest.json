{
  "manifest_version": 3,
  "name": "Sanctuary Metals Dialer",
  "version": "2.7.27",
  "key": "",
  "description": "Auto-dials a HubSpot contact list through an embedded RingCentral phone and logs each call back to HubSpot.",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["storage", "unlimitedStorage", "declarativeNetRequest", "identity"],
  "host_permissions": [
    "https://app.hubspot.com/*",
    "https://app-na1.hubspot.com/*",
    "https://app-na2.hubspot.com/*",
    "https://app-eu1.hubspot.com/*",
    "https://apps.ringcentral.com/*",
    "https://api.hubapi.com/*",
    "https://platform.ringcentral.com/*",
    "https://dialer-backend.sanctuarymetalsdialer.workers.dev/*",
    "https://raw.githubusercontent.com/*"
  ],
  "background": { "service_worker": "background.js" },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "csp_relax",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.hubspot.com/*",
        "https://app-na1.hubspot.com/*",
        "https://app-na2.hubspot.com/*",
        "https://app-eu1.hubspot.com/*"
      ],
      "js": ["content.js"],
      "css": ["panel.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["badge.png"],
      "matches": [
        "https://app.hubspot.com/*",
        "https://app-na1.hubspot.com/*",
        "https://app-na2.hubspot.com/*",
        "https://app-eu1.hubspot.com/*"
      ]
    }
  ]
}
